{
  "name": "gps-visualizer",
  "version": "1.5.0",
  "description": "GPS 轨迹可视化工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build-mac": "electron-builder --mac",
    "build-win": "electron-builder --win",
    "build-linux": "electron-builder --linux",
    "publish": "electron-builder --mac --win --publish always"
  },
  "keywords": [
    "gps",
    "visualizer",
    "map"
  ],
  "author": "顾侃健",
  "license": "MIT",
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.gukanjian.gps-visualizer",
    "productName": "GPS 可视化工具",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "icon.icns",
      "artifactName": "GPS-Visualizer-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico",
      "artifactName": "GPS-Visualizer-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": "AppImage"
    },
    "publish": {
      "provider": "github",
      "owner": "124618582-lang",
      "repo": "gu-tools",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "sql.js": "^1.14.1"
  }
}
