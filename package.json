{
  "name": "gps-visualizer",
  "version": "1.0.0",
  "description": "GPS 轨迹可视化工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build-mac": "electron-builder --mac",
    "build-win": "electron-builder --win",
    "build-linux": "electron-builder --linux"
  },
  "keywords": [
    "gps",
    "visualizer",
    "map"
  ],
  "author": "顾侃健",
  "license": "MIT",
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.gukanjian.gps-visualizer",
    "productName": "GPS 可视化工具",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "mac": {
      "target": "dmg",
      "icon": "icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "sql.js": "^1.14.1"
  }
}
